<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Workshops</h1>
  <div class="flex gap-2">
    <%= link_to "New Workshop", new_workshop_path, class: "btn btn-primary" %>
    <%= link_to "New Validated Workshop", new_validated_workshop_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="overflow-x-auto">
  <table class="table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Slug</th>
        <th>Category</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% workshops.each do |w| %>
        <tr>
          <td><%= w.title %></td>
          <td class="font-mono text-sm"><%= w.slug %></td>
          <td><%= w.category %></td>
          <td><span class="badge"><%= w.status %></span></td>
          <td class="flex gap-2 justify-end">
            <%= link_to "Show", workshop_path(w), class: "btn btn-xs" %>
            <%= link_to "Edit", edit_workshop_path(w), class: "btn btn-xs" %>
            <%= link_to "Edit (Validated)", edit_validated_workshop_path(w), class: "btn btn-xs btn-secondary" %>
            <%= button_to "Delete", workshop_path(w), method: :delete, class: "btn btn-xs btn-error", data: {turbo_confirm: "Delete this workshop?"} %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
