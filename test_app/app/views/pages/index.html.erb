<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Pages</h1>
  <%= link_to "New Page", new_page_path, class: "btn btn-primary" %>
</div>

<div class="overflow-x-auto">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Type</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% pages.each do |p| %>
        <tr>
          <td><%= p.name %></td>
          <td><%= p.system? ? tag.span("System", class: "badge badge-warning") : tag.span("Custom", class: "badge") %></td>
          <td class="flex gap-2 justify-end">
            <%= link_to "Edit", edit_page_path(p), class: "btn btn-xs" %>
            <% unless p.system? %>
              <%= button_to "Delete", page_path(p), method: :delete, class: "btn btn-xs btn-error", data: {turbo_confirm: "Delete this page?"} %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
